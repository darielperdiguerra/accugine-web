import React from 'react';
import { QuoteForm } from '../components/QuoteForm';

const RequestQuotePage = () => {
  
  // Data for your 4 specific PDFs
  const catalogues = [
    { id: 1, label: 'Regular Blinds 2026', filename: 'accugine-regular-blinds2026.pdf' },
    { id: 2, label: 'Premium Noblesse 2026', filename: 'accugine-premium-noblesse2026.pdf' },
    { id: 3, label: 'Premium Roller 2026', filename: 'accugine-premium-roller2026.pdf' },
    { id: 4, label: 'Premium Combi 2026', filename: 'accugine-premium-combi2026.pdf' }
  ];

  const handleDownload = (filename) => {
    // Assumes files are in the /public/catalogues/ folder
    const link = document.createElement('a');
    link.href = `/catalogues/${filename}`; 
    link.setAttribute('download', filename);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  return (
    <main className="w-full pt-28 bg-[#fcfcfc] min-h-screen">
      <div className="max-w-7xl mx-auto px-6 py-16">
        <div className="grid grid-cols-1 lg:grid-cols-12 gap-16">
          
          {/* Main Form Column */}
          <div className="lg:col-span-7">
            <QuoteForm />
          </div>

          {/* Business Profile Sidebar */}
          <div className="lg:col-span-5">
             <div className="bg-[#081a2e] p-10 text-white rounded-2xl sticky top-32 border-b-4 border-blue-600">
                <h3 className="text-xl font-black uppercase mb-2 italic">Product Catalogues</h3>
                <p className="text-gray-400 text-[11px] font-bold uppercase tracking-widest mb-8">
                  2026 Engineering Specifications
                </p>
                
                {/* 4 INDIVIDUAL BUTTONS */}
                <div className="space-y-4">
                  {catalogues.map((item) => (
                    <button 
                      key={item.id}
                      onClick={() => handleDownload(item.filename)}
                      className="group w-full flex items-center justify-between p-4 bg-white/5 border border-white/10 hover:bg-blue-600 hover:border-blue-500 transition-all rounded-xl text-left"
                    >
                      <span className="text-[10px] font-black uppercase tracking-widest leading-tight">
                        {item.label}
                      </span>
                      <svg xmlns="http://www.w3.org/2000/svg" className="h-4 w-4 text-blue-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={3} d="召 M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                      </svg>
                    </button>
                  ))}
                </div>

                <div className="mt-8 pt-6 border-t border-white/10">
                  <p className="text-[9px] text-gray-500 font-medium leading-relaxed italic">
                    Note: All files are in PDF format and include latest hardware specifications for Accugine 2026 lines.
                  </p>
                </div>
             </div>
          </div>

        </div>
      </div>
    </main>
  );
};

export default RequestQuotePage;